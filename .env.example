# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# HS256 JWT secret (Supabase dashboard → Settings → API). Used by the API to
# verify Supabase Auth tokens locally; leave empty to use JWKS discovery.
SUPABASE_JWT_SECRET=

# Postgres connection string (Supabase → Settings → Database, or local stack)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:54322/postgres

# ── Web (Next.js — set in apps/web/.env.local; Vercel env in prod) ──────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Infra ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
APP_ENV=development            # development | staging | production
PUBLIC_WEB_URL=http://localhost:3000
PDF_RENDER_CONCURRENCY=2

# ── AI providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=

# ── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# ── Subscriptions ───────────────────────────────────────────────────────────
REVENUECAT_API_KEY=

# ── Messaging ───────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
RESEND_API_KEY=

# ── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN_API=
SENTRY_DSN_MOBILE=
SENTRY_DSN_WEB=
POSTHOG_KEY=
