{
  "name": "fieldquote",
  "private": true,
  "packageManager": "pnpm@10.26.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore",
    "prepare": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.5.0"
  }
}
